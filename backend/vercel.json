{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": [
        "node_modules/puppeteer-extra-plugin-stealth/evasions/**/*",
        "node_modules/puppeteer-extra-plugin-user-preferences/**/*",
        "node_modules/puppeteer-extra-plugin-user-data-dir/**/*"
      ]
    }
  }
}
